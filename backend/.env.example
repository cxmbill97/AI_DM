# Copy this file to .env and fill in your values.
# Get a MiniMax API key at: https://www.minimaxi.com/
MINIMAX_API_KEY=your_minimax_api_key_here

# IMPORTANT: set a stable JWT_SECRET so that iOS tokens survive backend restarts.
# If unset, a new random secret is generated on every restart — existing tokens
# become invalid and iOS users will appear as random guest accounts.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace_with_a_stable_random_hex_string
